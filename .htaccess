# ===========================================
# .htaccess RACINE - À SUPPRIMER SUR LE SERVEUR
# ===========================================
# Ce fichier ne doit PAS être déployé sur le serveur
# si le DocumentRoot pointe déjà vers public/
# 
# Sur cPanel avec sous-domaine pointant vers public/
# SUPPRIMEZ ce fichier du serveur.
#
# Gardez uniquement :
# - public/.htaccess (pour le routage)
# - assets/.htaccess (optionnel)
# ===========================================

# Pour développement local uniquement
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Rediriger vers public/ (LOCAL UNIQUEMENT)
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} !^/assets/
    RewriteCond %{REQUEST_URI} !^/uploads/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# ===========================================
# PROTECTION DES FICHIERS SENSIBLES
# ===========================================

# Bloquer config.php
<Files "config.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>

# Bloquer composer.json et composer.lock
<FilesMatch "^composer\.(json|lock)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquer .git
<IfModule mod_rewrite.c>
    RewriteRule ^\.git - [F,L]
</IfModule>
RedirectMatch 404 /\.git

# Bloquer vendor/
<IfModule mod_rewrite.c>
    RewriteRule ^vendor/ - [F,L]
</IfModule>

# Bloquer src/
<IfModule mod_rewrite.c>
    RewriteRule ^src/ - [F,L]
</IfModule>

# Bloquer les fichiers cachés (sauf .well-known)
<IfModule mod_rewrite.c>
    RewriteRule ^\.(?!well-known) - [F,L]
</IfModule>

# ===========================================
# EN-TÊTES DE SÉCURITÉ
# ===========================================
<IfModule mod_headers.c>
    # Protection XSS
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://html2canvas.hertzen.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://accounts.google.com;"
    
    # Protection clickjacking
    Header always set X-Frame-Options "DENY"
</IfModule>

# ===========================================
# CONFIGURATION PHP
# ===========================================
<IfModule mod_php.c>
    # Sécurité des sessions
    php_value session.cookie_httponly 1
    php_value session.cookie_secure 1
    php_value session.use_strict_mode 1
    php_value session.use_only_cookies 1
    
    # Limites d'upload
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    
    # Désactiver l'affichage des erreurs en production
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>

# ===========================================
# DÉSACTIVER LISTAGE DES RÉPERTOIRES
# ===========================================
Options -Indexes

# ===========================================
# REDIRECTION HTTPS (optionnel - à activer si SSL)
# ===========================================
